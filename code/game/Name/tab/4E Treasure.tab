#
# 4E Treasure
#
# Note: Magic item generation for level 30 might not be
# entirely correct; the RC is a little unclear on this.
#

%level%,0
%groupmod%,0
%groupsize%,0
%coins%,none
%gems%,none
%art%,none
%magic%,none
%dieroll%,0
%modroll%,0
%nat20%,0
%group%,0
%type%,0
%list%,0
%x%,0
%min%,0
%max%,0
%val%,0
%magicdie%,0
%magiclvl%,0
%magicrarity%,0

@level,1,Enter level (1-30):
@groupsize,5,Enter size of group:

:Start
1,|groupmod={Calc~(%groupsize%-5)*2}|
_{Bold~Coins: }|type=Coins|[Generate]{CR~}
_{Bold~Gems: }|type=Gems|[Generate]{CR~}
_{Bold~Art: }|type=Art|[Generate]{CR~}
_{Bold~Magic: }[GenMagic]

:Generate
1,|group=L%level%_%type%|
_|dieroll={Dice~1d20}||modroll={Calc~%dieroll%+%groupmod%}|
_{If~%dieroll%=20?[Nat20Roll]}
_[%group%=%modroll%]

:GenMagic
1,|dieroll={Dice~1d20}||modroll={Calc~%dieroll%+%groupmod%}|
_|magicdie={If~%level%>26?{Calc~30-%level%}/4}|
_{If~%level%<30?[Magic1to29=%modroll%]/[Magic30=%modroll%]}

:Magic1to29
1-12,none
13-20,|magiclvl={Dice~1d%magicdie%+%level%}|[MagicRarity][MagicL%magiclvl%%magicrarity%] (level %magiclvl%, %magicrarity%)

:Magic30
1-12,none
13-18,|magiclvl=30|[MagicRarity][MagicL%magiclvl%%magicrarity%] (level %magiclvl%, %magicrarity%)
19-20,[Magic30=18], [Magic30=18]

:Nat20Roll
1,{If~[%group%=%modroll%]=none?[GiveLesser]/|modroll=20|}

:GiveLesser
1,{If~{Count~%group%}=2?|modroll=20|/|modroll={MinVal~%group%,2}|}

:MagicRarity
1,|magicrarity={If~{Mod~%dieroll%,2}=1?common/{If~%dieroll%=20?rare/uncommon}}|

:FixList
1,|list={Left~{Calc~{Length~%list%}-2},%list%}|

:GenGems
1,{Split~x,",",min,max,val}|list={Loop~{Dice~%min%d%max%},[Gems%val%] (%val% gp), }|[FixList]%list%

:GenArt
1,{Split~x,",",min,max,val}|list={Loop~{Dice~%min%d%max%},[Art%val%] (%val% gp), }|[FixList]%list%

:L1_Coins
1-10,none
11-14,{Dice~2d6*100} sp
15-20,{Dice~2d6*10} gp

:L1_Gems
1-17,none
18-20,|x=1,2,100|[GenGems]

:L1_Art
1-19,none
20,|x=1,1,250|[GenArt]

