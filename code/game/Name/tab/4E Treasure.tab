# ===============
# Art objects
# ===============
;Art250
1,gold ring with [Gems100]
1,{If~{Dice~1d2}=1?bone/ivory} statuette
1,gold bracelet
1,silver necklace
1,bronze crown
1,silver-plated sword
1,silk robe

;Art1500
1,gold ring with [Gems1000]
1,{If~{Dice~1d2}=1?gold/silver} statuette
1,gold bracelet with {Plural~[Gems500]}
1,gold necklace with {Plural~[Gems100]}
1,silver {If~{Dice~1d2}=1?tiara/crown} with {Plural~[Gems100]}
1,ivory comb with {Plural~[Gems500]}
1,cloth of gold vestments

;Art2500
1,{If~{Dice~1d2}=1?gold/platinum} ring with {Plural~[Gems1000]}
1,{If~{Dice~1d2}=1?gold/silver} statuette with {Plural~[Gems500]}
1,gold necklace with {Plural~[Gems500]}
1,gold crown with {Plural~[Gems500]}
1,gold chalice with {Plural~[Gems100]}
1,ceremonial gold breastplate

;Art7500
1,platinum ring with {Plural~[Gems5000]}
1,gold statuette with {Plural~[Gems1000]}
1,mithral necklace with {Plural~[Gems1000]}
1,adamantine crown with {Plural~[Gems1000]}
1,adamantine box containing elemental flame
1,black tunic woven of pure shadow

;Art15000
1,mithral ring with an astral diamond
1,gold statuette with {Plural~[Gems5000]}
1,gold necklace with {Plural~[Gems5000]}
1,mithral tiara with {Plural~[Gems5000]}
1,cup of celestial gold that glows with a soft inner light
1,silvery cloak of astral thread
1,enormous {If~{Dice~1d2}=1?emerald/sapphire}

;Art50000
1,bracelet formed of cold elemental lightning
1,gown woven of elemental water
1,brass ring with bound elemental fire
1,celestial gold statuette with astral diamonds
1,royal attire of astral thread with {Plural~[Gems5000]}
1,enormous {If~{Dice~1d2}=1?diamond/ruby}

