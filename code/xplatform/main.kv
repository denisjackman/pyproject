ScreenManager:
    ListScreen:
    TextScreen:

<ListScreen>:
    id: list
    name: "list"
    MDBoxLayout:
        id: mylayout
        orientation: "vertical"
        padding: "15dp"
        MDTopAppBar:
            title: "Notes"
        ScrollView:
            MDList
                id: container
        MDTextField:
            id: note
            multiline: True
            hint_text: "Write a note"
        MDRectangleFlatButton:
            text: "Create note"
            pos_hint: {"center_x": .5, "center_y": .1}
            on_press: app.add_note()

<TextScreen>:
    id: text
    name: "text"
    MDBoxLayout:
        id: mynotes
        orientation: "vertical"
        padding: "15dp"
        MDTopAppBar:
            title: "Notes"
        ScrollView:
            MDLabel
                id: fulldescription
                text: ""
                halign: "center"
        MDRectangleFlatButton:
            text: "Return"
            pos_hint: {"center_x": .5, "center_y": .1}
            on_press: root.manager.current="list"
